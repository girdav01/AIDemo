# TrendAI Vision One AI Security Challenge Passport — environment config
#
# The booth app runs fully OFFLINE with a deterministic mock bot if no key is set,
# so it never breaks at the booth. Set a key only if you want a live Claude bot
# behind the "Break the Bot" station.

# Optional: enables the live Claude-powered demo chatbot for Challenge 1.
# Leave blank to use the deterministic offline bot (recommended for booth reliability).
ANTHROPIC_API_KEY=

# Model for the live demo bot. Defaults to claude-opus-4-8.
# For a high-volume booth you can switch to claude-haiku-4-5 for speed/cost.
ANTHROPIC_MODEL=claude-opus-4-8

# Host/port for the app
HOST=0.0.0.0
PORT=8000

# Public URL the booth is reachable at from attendee phones (e.g. the LAN IP).
# Used for e-passport QR codes so they don't encode "localhost". If blank, the
# QR uses whatever URL the page was opened with — set this when the page is
# opened on the booth machine via localhost.
BOOTH_URL=

# Staff admin credentials (the /admin page). Change these for a real booth.
STAFF_USER=TrendAIStaff
STAFF_PASS=Tr3nd8i!

# Persist passports + leaderboard to SQLite so a restart doesn't wipe the board.
BOOTH_PERSIST=1
BOOTH_DB=booth_state.db
